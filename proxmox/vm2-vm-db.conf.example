# Configuración VM2 vm-db en Proxmox VE
# ID: 101
args: -cpu host
boot: order=scsi0
cores: 2
efidisk0: local-zfs:vm-101-disk-0,efitype=4m,pre-enrolled-keys=1,size=4M
machine: pc-q35-8.1
memory: 3072
name: vm-db
net0: virtio=BC:24:11:5F:CB:99,bridge=vmbr0,firewall=1
ostype: l26
scsi0: local-zfs:vm-101-disk-0,cache=writeback,size=20G
scsihw: virtio-scsi-single
